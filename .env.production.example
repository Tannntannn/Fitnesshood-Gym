# Production (Vercel + Supabase Postgres)
# Copy these keys into Vercel Project Settings -> Environment Variables

DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Optional but recommended for Prisma schema changes/migrations from your machine:
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-<region>.pooler.supabase.com:5432/postgres?sslmode=require"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_service_role_xxx"


