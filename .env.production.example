# Production (Vercel + Supabase Postgres)
# Copy these keys into Vercel Project Settings -> Environment Variables.
# Do not commit real passwords. Use Supabase Settings -> Database -> Connection strings.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
# Prisma migrations / long transactions (direct connection, not pooler transaction mode):
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_service_role_xxx"
SUPABASE_PROFILE_BUCKET="profile-images"

# Email (password reset, etc.) — use a verified domain sender in Resend
RESEND_API_KEY="re_xxx"
MAIL_FROM="FitnessHood <no-reply@your-domain.com>"

# Optional: manual / non-Vercel runs of GET /api/cron/loyalty-expire (Vercel Cron uses x-vercel-cron; set this for Bearer auth)
# CRON_SECRET="replace-with-long-random-string"