generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MEMBER
  NON_MEMBER
  WALK_IN
  WALK_IN_REGULAR
}

enum PaymentMethod {
  CASH
  GCASH
  CARD
  BANK_TRANSFER
  MAYA
  OTHER
  SPLIT
}

enum PaymentCollectionStatus {
  FULLY_PAID
  PARTIAL
}

enum PaymentTransactionType {
  LEGACY
  MEMBERSHIP_CONTRACT
  MONTHLY_FEE
  WALK_IN
  ADD_ON
  OTHER
}

enum PaymentDiscountType {
  NONE
  PERCENT
  FIXED
}

enum LoyaltyApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipLifecycleStatus {
  ACTIVE
  WARNING
  EXPIRED
  NO_EXPIRY
}

enum MembershipPenaltySource {
  AUTO
  MANUAL
}

model User {
  id          String       @id @default(cuid())
  firstName   String
  lastName    String
  contactNo   String       @default("")
  email       String?      @db.Text
  address     String?      @db.Text
  notes       String?      @db.Text
  profileImageUrl String?  @db.Text
  memberPasswordHash String? @db.Text
  resetPasswordTokenHash String? @db.Text
  resetPasswordExpiresAt DateTime?
  role        UserRole
  qrCode      String       @unique
  qrCodeImage String

  membershipStart  DateTime?
  membershipExpiry DateTime?
  membershipTier   String?      @db.Text
  lockInLabel      String?      @db.Text
  monthlyFeeLabel  String?      @db.Text
  membershipFeeLabel String?    @db.Text
  gracePeriodEnd   DateTime?
  freezeStatus     String?      @db.Text
  freezeStartedAt  DateTime?
  freezeEndsAt     DateTime?
  freezeDaysTotal  Int?
  membershipNotes  String?      @db.Text
  coachName      String?      @db.VarChar(120)
  monthlyExpiryDate DateTime?
  fullMembershipExpiry DateTime?
  daysLeft       Int?
  membershipStatus MembershipLifecycleStatus?
  monthsPaid     Int          @default(0)
  remainingMonths Int?
  totalContractPrice Decimal? @db.Decimal(10, 2)
  remainingBalance Decimal?   @db.Decimal(10, 2)
  loyaltyStars   Int          @default(0)
  membershipPenalty       Boolean                   @default(false)
  membershipPenaltySource MembershipPenaltySource?
  membershipPenaltyNotes  String?                   @db.Text

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  syncedAt    DateTime?
  attendance  Attendance[]
  payments    Payment[]
  loyaltyLedger LoyaltyLedger[]
  loyaltyClaims LoyaltyClaim[]
  addOnSubscriptions AddOnSubscription[]
}

model Coach {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(120)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commissionRemittances CoachCommissionRemittance[]
}

// Coach commission remittance: coach pays gym (manual entry).
model CoachCommissionRemittance {
  id               String          @id @default(cuid())
  coachId          String
  coach            Coach           @relation(fields: [coachId], references: [id], onDelete: Restrict)
  amount           Decimal         @db.Decimal(10, 2)
  paidAt           DateTime
  paymentMethod    PaymentMethod   @default(CASH)
  paymentReference String?         @db.VarChar(255)
  notes            String?         @db.Text
  recordedBy       String?         @db.VarChar(255)
  createdAt        DateTime        @default(now())

  @@index([coachId, paidAt])
  @@index([paidAt])
}

model Attendance {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleSnapshot UserRole
  scannedAt    DateTime @default(now())
  date         DateTime
  timeIn       String
  timeOut      String?
  checkedOutAt DateTime?
  dayOfWeek    String
  month        Int
  year         Int
  updatedAt    DateTime @updatedAt
  syncedAt     DateTime?

  @@index([userId, scannedAt])
  @@index([roleSnapshot, date])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Service {
  id             String    @id @default(cuid())
  name           String
  tier           String
  contractMonths Int
  monthlyRate    Decimal   @db.Decimal(10, 2)
  membershipFee  Decimal   @db.Decimal(10, 2)
  contractPrice  Decimal   @db.Decimal(10, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
  addOnSubscriptions AddOnSubscription[]

  @@unique([name, tier])
  @@index([tier, isActive])
}

model Payment {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  amount        Decimal        @db.Decimal(10, 2)
  grossAmount   Decimal?       @db.Decimal(10, 2)
  discountPercent Int?
  discountAmount Decimal?      @db.Decimal(10, 2)
  discountType  PaymentDiscountType @default(NONE)
  discountFixedAmount Decimal? @db.Decimal(10, 2)
  discountReason String?       @db.Text
  paymentMethod PaymentMethod
  collectionStatus PaymentCollectionStatus @default(FULLY_PAID)
  transactionType PaymentTransactionType @default(LEGACY)
  approvedBy    String?        @db.VarChar(191)
  recordedBy    String?        @db.VarChar(191)
  paidAt        DateTime       @default(now())
  isSplit       Boolean        @default(false)
  notes         String?        @db.Text
  customAddOnLabel String?    @db.VarChar(200) // one-time POS add-on label (Add-on / Custom service)
  receiptGroupId   String?    @db.VarChar(36) // same id on lines saved together → one record bubble + combined receipt
  paymentReference String?     @db.VarChar(255)
  addOnSubscriptionId String?
  addOnSubscription AddOnSubscription? @relation(fields: [addOnSubscriptionId], references: [id], onDelete: SetNull)
  splitPayments SplitPayment[]
  loyaltyLedger LoyaltyLedger[]
  createdAt     DateTime       @default(now())

  @@index([paidAt])
  @@index([userId, paidAt])
  @@index([serviceId, paidAt])
  @@index([addOnSubscriptionId])
}

model SplitPayment {
  id         String        @id @default(cuid())
  paymentId  String
  payment    Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  method     PaymentMethod
  amount     Decimal       @db.Decimal(10, 2)
  reference  String?       @db.VarChar(255)
  createdAt  DateTime      @default(now())

  @@index([paymentId])
}

model ClientAnnouncement {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(180)
  message   String   @db.Text
  imageUrl  String?  @db.Text
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@index([updatedAt])
}

model LoyaltyLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  points    Int
  pointsEarned Int @default(0)
  pointsDeducted Int @default(0)
  remainingBalance Int?
  reason    String   @db.VarChar(80)
  reasonDetail String? @db.Text
  transactionReference String? @db.VarChar(120)
  adminApproval LoyaltyApprovalStatus @default(APPROVED)
  adjustedBy String? @db.VarChar(191)
  adjustedAt DateTime?
  claimId String?
  claim   LoyaltyClaim? @relation(fields: [claimId], references: [id], onDelete: SetNull)
  amountBasis Decimal? @db.Decimal(10, 2)
  rewardUsed Boolean @default(false)
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([paymentId])
  @@index([claimId])
}

model LoyaltyClaim {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardName    String   @db.VarChar(120)
  pointsRequired Int
  status        LoyaltyApprovalStatus @default(PENDING)
  approvedBy    String?  @db.VarChar(191)
  approvedAt    DateTime?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ledgerEntries LoyaltyLedger[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AddOnSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceId    String?
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  addonName    String   @db.VarChar(120)
  dueDate      DateTime?
  status       String   @default("ACTIVE") @db.VarChar(20)
  lastPaymentAt DateTime?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  payments     Payment[]

  @@index([userId, status])
  @@index([dueDate])
}
